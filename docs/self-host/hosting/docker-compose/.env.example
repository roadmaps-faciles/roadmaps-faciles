# Domaine public et email Let's Encrypt
PUBLIC_DOMAIN=feedback.example.com
ACME_EMAIL=contact@example.com

# Branding
BRAND_NAME="Mon instance Roadmaps"

# Admins (séparés par virgule, ce sont les usernames qui auront accès au root admin)
ADMINS=alice,bob

# Image tag (latest, dev, ou un tag spécifique v1.2.3)
WEB_IMAGE_TAG=latest

# Secrets à GÉNÉRER (jamais réutiliser ceux d'un exemple ou d'un autre env)
#   AUTH_SECRET                : openssl rand -base64 32
#   SECURITY_JWT_SECRET        : openssl rand -base64 32
#   SECURITY_WEBHOOK_SECRET    : openssl rand -base64 32
#   INTEGRATION_ENCRYPTION_KEY : openssl rand -base64 32
AUTH_SECRET=
SECURITY_JWT_SECRET=
SECURITY_WEBHOOK_SECRET=
INTEGRATION_ENCRYPTION_KEY=

# Postgres
POSTGRES_PASSWORD=changeme

# Garage (S3 local, v2.3.0)
#
# IMPORTANT : avant le premier `docker compose up` :
#   1. Générer le rpc_secret dans garage.toml :
#        sed -i "s/REPLACE_WITH_OPENSSL_RAND_HEX_32/$(openssl rand -hex 32)/" garage.toml
#   2. Générer access key + secret ci-dessous (format documenté par Garage) :
#        GK suivi de 32 chars hex pour l'access key, 64 chars hex pour le secret
#        GARAGE_DEFAULT_ACCESS_KEY="GK$(openssl rand -hex 16)"
#        GARAGE_DEFAULT_SECRET_KEY="$(openssl rand -hex 32)"
#   3. Garage créera automatiquement le bucket + la key au premier boot
#      (flag --default-bucket dans le compose).
GARAGE_DEFAULT_ACCESS_KEY=GK
GARAGE_DEFAULT_SECRET_KEY=
STORAGE_S3_BUCKET=roadmaps-faciles
STORAGE_MAX_FILE_SIZE_MB=5

# SMTP (Resend, Brevo, Mailjet, etc.)
MAILER_SMTP_HOST=smtp.resend.com
MAILER_SMTP_PORT=587
MAILER_SMTP_SSL=false
MAILER_SMTP_LOGIN=resend
MAILER_SMTP_PASSWORD=
MAILER_FROM_EMAIL="Roadmaps <noreply@example.com>"

# Multi-tenant routing : ajouter ici les domaines internes que votre proxy/healthcheck utilise
# (ex: 127.0.0.1:3000, localhost:3000)
ADDITIONAL_ROOT_DOMAINS=

# =============================================================================
# DÉPLOIEMENT GOUVERNEMENTAL (optionnel)
# Voir docs/self-host/GOUVERNEMENTAL.md pour le détail de chaque variable.
# Décommenter et renseigner uniquement pour un usage secteur public.
# =============================================================================

# --- Licence Gov ------------------------------------------------------------
# Clé de licence (format rf_live_...). Vide = mode community (pas de DSFR ni features EE).
# Une clé GOV_LICENSED est requise pour activer le thème DSFR.
#LICENSE_KEY=
# Serveur de vérification de licence (ne pas changer en self-host).
#LICENSING_SERVER_URL=https://licensing.roadmaps-faciles.fr
# Identifiant d'instance (optionnel : auto-généré et persisté si vide).
#INSTANCE_ID=

# --- Bootstrap d'instance (POST /api/setup) ---------------------------------
# Activer la route /api/setup en posant un jeton secret (openssl rand -base64 32).
# Sans SETUP_TOKEN, la route renvoie 403. La route est idempotente (409 si déjà initialisée).
#SETUP_TOKEN=
# Valeurs par défaut du premier admin et tenant (fallback si le corps JSON ne les fournit pas).
#SEED_ADMIN_NAME=Admin
#SEED_ADMIN_EMAIL=admin@monministere.gouv.fr
#SEED_ADMIN_USERNAME=admin
# Mot de passe admin : vide = connexion par magic link (SMTP requis).
#SEED_ADMIN_PASSWORD=
#SEED_TENANT_NAME=Mon Service
#SEED_TENANT_SUBDOMAIN=default

# --- Authentification ProConnect (OIDC État) --------------------------------
# Les TROIS variables sont requises. Sans ISSUER, le provider est ignoré (warn dans les logs).
# Issuer prod ProConnect : vérifier la valeur courante dans la doc ProConnect.
#OAUTH_PROCONNECT_CLIENT_ID=
#OAUTH_PROCONNECT_CLIENT_SECRET=
#OAUTH_PROCONNECT_ISSUER=https://auth.agentconnect.gouv.fr/api/v2

# --- Authentification Espace Membre (beta.gouv) -----------------------------
#ESPACE_MEMBRE_API_KEY=
#ESPACE_MEMBRE_URL=https://espace-membre.incubateur.net

# --- Branding État ----------------------------------------------------------
# Bloc marque de l'État (le \n force le retour à la ligne).
#NEXT_PUBLIC_BRAND_MINISTRY="Ministère\nde l'Exemple"
#NEXT_PUBLIC_BRAND_OPERATOR_ENABLE=true
#NEXT_PUBLIC_BRAND_OPERATOR_LOGO_URL=/img/mon-operateur.png
#NEXT_PUBLIC_BRAND_OPERATOR_LOGO_ALT="Mon opérateur"
#NEXT_PUBLIC_BRAND_OPERATOR_LOGO_ORIENTATION=vertical

# --- Pages légales (à remplacer impérativement, défauts = Scalingo/Roadmaps Faciles) ---
#NEXT_PUBLIC_LEGAL_PUBLISHER_NAME="Mon Opérateur Public"
#NEXT_PUBLIC_LEGAL_PUBLISHER_ADDRESS="1 rue de l'Exemple, 75000 Paris, France"
#NEXT_PUBLIC_LEGAL_PUBLICATION_DIRECTOR="Nom du directeur de publication"
#NEXT_PUBLIC_LEGAL_HOSTING_NAME="Nom de l'hébergeur"
#NEXT_PUBLIC_LEGAL_HOSTING_ADDRESS="Adresse de l'hébergeur"
#NEXT_PUBLIC_LEGAL_HOSTING_CONTACT="contact@hebergeur.fr"
#NEXT_PUBLIC_LEGAL_HOSTING_PRIVACY_URL="https://hebergeur.fr/confidentialite"
#NEXT_PUBLIC_LEGAL_CONTACT_EMAIL="contact@monministere.gouv.fr"
#NEXT_PUBLIC_LEGAL_RGPD_EMAIL="dpo@monministere.gouv.fr"

# --- Conformité tracking (CNIL) ---------------------------------------------
# noop pour désactiver tout tracking, ou matomo auto-hébergé sans cookie.
#NEXT_PUBLIC_TRACKING_PROVIDER=noop
