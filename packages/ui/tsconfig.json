{
  "compilerOptions": {
    "strict": true,
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@roadmaps-faciles/ui": ["./src/index.ts"],
      "@roadmaps-faciles/ui/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "vitest.config.ts",
    "vitest.config.unit.ts",
    "vitest.config.storybook.ts",
    "vitest.setup.ts"
  ],
  "exclude": ["node_modules"]
}
