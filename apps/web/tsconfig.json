{
  "extends": "@tsconfig/next",
  "compilerOptions": {
    "strict": true,
    "downlevelIteration": true,
    "baseUrl": ".",
    "paths": {
      "fumadocs-mdx:collections/*": [
        ".source/*"
      ],
      "@/config": [
        "src/config.ts"
      ],
      "@/ui": [
        "src/ui/index.ts"
      ],
      "@/ui/*": [
        "src/ui/*"
      ],
      "@/gouv/dsfr": [
        "src/gouv/dsfr/server.ts"
      ],
      "@/gouv/dsfr/client": [
        "src/gouv/dsfr/client.ts"
      ],
      "@/gouv/dsfr/utils/*": [
        "src/gouv/dsfr/utils/*"
      ],
      "@/utils/*": [
        "src/lib/utils/*"
      ],
      "@/prisma/*": [
        "src/generated/prisma/*"
      ],
      "@roadmaps-faciles/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@roadmaps-faciles/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@/*": [
        "src/*"
      ],
    },
    "target": "ES2017"
  },
  "include": [
    "src/.well-known/**/*.ts*",
    "global.d.ts",
    "next-env.d.ts",
    "env.d.ts",
    "types/**/*.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "tailwind.config.ts",
    "eslint.config.ts",
  ],
  "exclude": [
    "node_modules",
    "prisma",
    "tests"
  ]
}