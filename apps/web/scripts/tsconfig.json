{
  "compilerOptions": {
    "lib": [
      "es2024"
    ],
    "module": "nodenext",
    "target": "es2024",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "paths": {
      "@/config": [
        "../src/config.ts"
      ],
      "@/gouv/dsfr": [
        "../src/gouv/dsfr/server.ts"
      ],
      "@/gouv/dsfr/client": [
        "../src/gouv/dsfr/client.ts"
      ],
      "@/gouv/dsfr/utils/*": [
        "../src/gouv/dsfr/utils/*"
      ],
      "@/utils/*": [
        "../src/lib/utils/*"
      ],
      "@/prisma/*": [
        "../src/generated/prisma/*"
      ],
      "@/*": [
        "../src/*"
      ]
    }
  },
  "ts-node": {
    "transpileOnly": true,
    "require": [
      "tsconfig-paths/register"
    ]
  }
}