{
  "name": "@roadmaps-faciles/licensing",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24"
  },
  "scripts": {
    "dev": "tsx --env-file-if-exists=.env --watch src/index.ts",
    "prebuild": "prisma generate",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "generate-keypair": "tsx scripts/generate-keypair.ts",
    "seed": "tsx --env-file-if-exists=.env scripts/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "hono": "^4.12.21",
    "pino": "^10.3.1",
    "stripe": "^22.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0"
  }
}
